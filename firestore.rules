rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    // Auth tokens in this environment don't have custom claims, so we look up in Firestore
    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }
    
    function isAdmin() {
      // Mandate email verification for admins as per security guidelines
      return isSignedIn() && (
        (getUserData(request.auth.uid).role == 'admin' && request.auth.token.email_verified == true) ||
        // Fallback for bootstrap admin if verification is pending during development
        (request.auth.token.email == 'naymarajiarkan@gmail.com')
      );
    }
    
    function isJury() {
      return isSignedIn() && getUserData(request.auth.uid).role == 'jury';
    }

    // --- User Rules ---
    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId) && (isOwner(userId) || isAdmin() || isJury());
      allow list: if isSignedIn() && (isAdmin() || isJury());
      
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'role', 'status', 'displayName', 'createdAt'])
          && data.keys().size() == 6
          && data.uid == userId
          && data.role in ['admin', 'jury', 'participant']
          && data.status in ['pending', 'active', 'locked']
          && data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100
          && data.createdAt is string;
      }

      allow create: if isSignedIn() && isOwner(userId) && isValidId(userId) && (
        (incoming().status == 'pending' && incoming().role in ['participant', 'jury'] && incoming().email == request.auth.token.email) ||
        (incoming().email == 'naymarajiarkan@gmail.com' && incoming().role == 'admin' && incoming().status == 'active')
      ) && isValidUser(incoming());
      
      allow update: if isSignedIn() && isValidId(userId) && (
          isAdmin() || 
          (isOwner(userId) && 
           incoming().role == existing().role && 
           incoming().status == existing().status && 
           incoming().email == existing().email)
        ) && isValidUser(incoming());
    }

    // --- Registration Rules ---
    match /registrations/{regId} {
      allow get: if isSignedIn() && isValidId(regId) && (isOwner(existing().userId) || isAdmin() || isJury());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin() || isJury());
      
      function isValidRegistration(data) {
        return data.keys().hasAll(['userId', 'competitionType', 'status', 'createdAt'])
          && data.keys().size() == 4
          && data.userId is string
          && data.competitionType in ['battle', 'seminar']
          && data.status in ['pending', 'confirmed', 'deactivated']
          && data.createdAt is string;
      }

      allow create: if isSignedIn() && isValidId(regId) && (isOwner(incoming().userId) || isAdmin())
        && isValidRegistration(incoming())
        && exists(/databases/$(database)/documents/users/$(incoming().userId));
        
      allow update: if isSignedIn() && isValidId(regId) && (isAdmin() || isJury()) && isValidRegistration(incoming());
      allow delete: if isSignedIn() && isValidId(regId) && isAdmin();
    }

    // --- Score Rules ---
    match /scores/{scoreId} {
      allow get: if isSignedIn() && isValidId(scoreId) && (isOwner(existing().participantId) || isAdmin() || isJury());
      allow list: if isSignedIn() && (resource.data.participantId == request.auth.uid || isAdmin() || isJury());
      
      function isValidScore(data) {
        return data.keys().hasAll(['participantId', 'juryId', 'juryName', 'scoreValues', 'totalScore', 'updatedAt'])
          && data.keys().size() == 6
          && data.participantId is string
          && data.juryId == request.auth.uid
          && data.scoreValues is map
          && data.totalScore is number
          && data.updatedAt is string;
      }

      allow create: if isSignedIn() && isValidId(scoreId) && (isJury() || isAdmin()) && isValidScore(incoming())
        && exists(/databases/$(database)/documents/users/$(incoming().participantId));
      allow update: if isSignedIn() && isValidId(scoreId) && (isJury() || isAdmin()) && isValidScore(incoming());
      allow delete: if isSignedIn() && isValidId(scoreId) && (isAdmin() || isJury());
    }

    // --- Event Rules ---
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
